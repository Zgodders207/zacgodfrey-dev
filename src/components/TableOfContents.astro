---
// This component will be populated by client-side JavaScript
// that scans the article for headings
---

<aside class="toc-wrapper">
	<nav class="toc" id="table-of-contents">
		<h2 class="toc-title">Table of Contents</h2>
		<ul class="toc-list" id="toc-list">
			<!-- Generated by JavaScript -->
		</ul>
	</nav>
</aside>

<style>
	.toc-wrapper {
		position: sticky;
		top: 80px;
		max-height: calc(100vh - 100px);
		overflow-y: auto;
		padding: 1.5rem;
		margin-bottom: 2rem;
		background: var(--subtle);
		border-radius: 8px;
		border: 1px solid var(--subtle);
	}

	.toc-title {
		font-size: 14px;
		font-weight: 600;
		color: var(--off-white);
		margin: 0 0 1rem 0;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.toc-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	:global(.toc-list li) {
		margin: 0;
		padding: 0;
	}

	:global(.toc-list a) {
		display: block;
		padding: 0.4rem 0;
		color: var(--muted);
		text-decoration: none;
		font-size: 14px;
		line-height: 1.4;
		transition: color 0.2s ease;
		border-left: 2px solid transparent;
		padding-left: 0.5rem;
	}

	:global(.toc-list a:hover) {
		color: var(--olive-text);
	}

	:global(.toc-list a.active) {
		color: var(--olive-text);
		border-left-color: var(--olive-text);
	}

	:global(.toc-list .toc-h3) {
		padding-left: 1.5rem;
		font-size: 13px;
	}

	:global(.toc-list .toc-h4) {
		padding-left: 2.5rem;
		font-size: 12px;
	}

	@media (max-width: 1200px) {
		.toc-wrapper {
			position: relative;
			top: 0;
			max-height: none;
		}
	}

	@media (max-width: 768px) {
		.toc-wrapper {
			display: none;
		}
	}
</style>

<script>
	// Generate table of contents from article headings
	function generateTableOfContents() {
		const article = document.querySelector('article');
		const tocList = document.getElementById('toc-list');
		const tocWrapper = document.querySelector('.toc-wrapper');

		if (!article || !tocList || !tocWrapper) return;

		// Find all h2, h3, and h4 headings in the article
		const headings = article.querySelectorAll('h2, h3, h4');

		// If there are less than 3 headings, hide the TOC
		if (headings.length < 3) {
			tocWrapper.style.display = 'none';
			return;
		}

		// Generate TOC list items
		headings.forEach((heading, index) => {
			const level = heading.tagName.toLowerCase();
			const text = heading.textContent || '';
			const id = heading.id || `heading-${index}`;

			// Add ID to heading if it doesn't have one
			if (!heading.id) {
				heading.id = id;
			}

			// Create list item and link
			const li = document.createElement('li');
			const a = document.createElement('a');
			a.href = `#${id}`;
			a.textContent = text;
			a.className = `toc-${level}`;

			// Smooth scroll on click
			a.addEventListener('click', (e) => {
				e.preventDefault();
				const target = document.getElementById(id);
				if (target) {
					target.scrollIntoView({ behavior: 'smooth', block: 'start' });
					// Update URL without jumping
					history.pushState(null, '', `#${id}`);
				}
			});

			li.appendChild(a);
			tocList.appendChild(li);
		});

		// Highlight active section on scroll
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					const id = entry.target.id;
					const link = tocList.querySelector(`a[href="#${id}"]`);
					if (link) {
						if (entry.isIntersecting) {
							// Remove active class from all links
							tocList.querySelectorAll('a').forEach((a) => a.classList.remove('active'));
							// Add active class to current link
							link.classList.add('active');
						}
					}
				});
			},
			{
				rootMargin: '-100px 0px -66%',
			}
		);

		// Observe all headings
		headings.forEach((heading) => observer.observe(heading));
	}

	// Run on page load
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', generateTableOfContents);
	} else {
		generateTableOfContents();
	}
</script>
