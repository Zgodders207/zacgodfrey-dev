---
// Custom cursor HTML elements
---

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<script>
	// Custom cursor tracking
	const cursor = document.getElementById('cursor');
	const ring = document.getElementById('cursorRing');

	document.addEventListener('mousemove', (e) => {
		if (cursor && ring) {
			cursor.style.left = e.clientX + 'px';
			cursor.style.top = e.clientY + 'px';
			cursor.style.opacity = '1';
			ring.style.left = e.clientX + 'px';
			ring.style.top = e.clientY + 'px';
			ring.style.opacity = '1';
		}
	});

	// Cursor size change on interactive elements
	const interactiveElements = document.querySelectorAll('a, button, .post-card, .project-row');
	interactiveElements.forEach((el) => {
		el.addEventListener('mouseenter', () => {
			if (cursor && ring) {
				cursor.style.width = '10px';
				cursor.style.height = '10px';
				ring.style.width = '48px';
				ring.style.height = '48px';
				ring.style.borderColor = 'rgba(107,156,10,0.7)';
			}
		});
		el.addEventListener('mouseleave', () => {
			if (cursor && ring) {
				cursor.style.width = '6px';
				cursor.style.height = '6px';
				ring.style.width = '32px';
				ring.style.height = '32px';
				ring.style.borderColor = 'rgba(107,156,10,0.4)';
			}
		});
	});
</script>
